# ── Database & Cache ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neuralgate
REDIS_URL=redis://localhost:6379

# ── Provider API Keys (add any you have — router skips unavailable ones) ──────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...          # Also required for semantic cache embeddings
DEEPSEEK_API_KEY=sk-...
GOOGLE_API_KEY=AIzaSy...
# XAI_API_KEY=xai-...
# MISTRAL_API_KEY=...

# ── Proxy settings ────────────────────────────────────────────────────────────
# PROXY_API_KEY=change-me            # Uncomment to require Bearer auth
CACHE_SIMILARITY_THRESHOLD=0.88      # Cosine similarity threshold for semantic cache (0.0–1.0)
DEFAULT_CACHE_TTL_HOURS=24
